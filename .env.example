# Stockwise waitlist — all optional. Missing vars no-op that integration.

# Slack incoming webhook — posts a message on every signup.
SLACK_WEBHOOK_URL=

# Resend — sending email notifications to the founder.
RESEND_API_KEY=
FROM_EMAIL="Stockwise <hello@stockwise.app>"
NOTIFY_EMAIL=you@example.com

# Security — comma-separated origin allowlist (Origin header must match).
# Defaults to https://stockwise.app + https://www.stockwise.app if unset.
ALLOWED_ORIGINS=https://stockwise.app,https://www.stockwise.app

# Max submissions per IP per minute (default 5).
RATE_LIMIT_PER_MIN=5
